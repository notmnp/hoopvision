{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "experimentalServices": {
    "web": {
      "entrypoint": "frontend",
      "routePrefix": "/",
      "framework": "vite"
    },
    "api": {
      "entrypoint": "backend/app/api.py",
      "routePrefix": "/api",
      "framework": "fastapi",
      "memory": 1024,
      "maxDuration": 300,
      "excludeFiles": "frontend/**"
    }
  }
}
